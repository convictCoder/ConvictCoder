---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import alanaJpg from "../assets/alana.jpg";
---

<BaseLayout title="Alana | Portfolio Card" description="I’m a full-stack developer turning lessons learned the hard way into software that actually matters.">
		<Card
			name="Alana"
			position="Full Stack Developer"
			aboutMe="From prison bars to code blocks, I build software that matters"
			linkedin="https://www.linkedin.com/in/alanaandres"
			github="https://github.com/convictCoder"
			portfolioLink="https://fornnitefavs.netlify.app/"
			resumeLink="/resume.pdf"
			profileImage={alanaJpg}
		/>
</BaseLayout>
