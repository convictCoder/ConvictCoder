---
const {
  name,
  position,
  aboutMe,
  linkedin,
  github,
  portfolioLink,
  profileImage,
  resumeLink,
} = Astro.props;
import "../styles/card.css";
import ProfileImage from "./ProfileImage.astro";
import QuickNote from "./QuickNote.jsx";
---

<div class="container">
  <div class="card-container">
    <div class="description1">
      <h1>{name}</h1>
      <h2>{position}</h2>
      <p>{aboutMe}</p>
      <QuickNote client:load />
      <div class="icons">
        <a href={linkedin} class="hover-text" target="_blank" rel="noreferrer" aria-label="LinkedIn profile">
          <span class="tooltip-text"> LinkedIn </span>
          <i class="bi bi-linkedin"></i>
        </a>
        <a href={github} class="hover-text" target="_blank" rel="noreferrer" aria-label="GitHub profile">
          <span class="tooltip-text"> GitHub </span>
          <i class="bi bi-github"></i>
        </a>
        <a href={portfolioLink} class="hover-text" target="_blank" rel="noreferrer" aria-label="Portfolio site">
          <span class="tooltip-text"> Portfolio </span>
          <i class="bi bi-controller"></i>
        </a>
        {
          resumeLink && (
            <a href={resumeLink} class="hover-text" target="_blank" rel="noreferrer" aria-label="Resume PDF">
              <span class="tooltip-text">
                Resume
              </span>
              <i class="bi bi-file-earmark-person" />
            </a>
          )
        }
      </div>
    </div>
    <ProfileImage src={profileImage} alt={`${name} portrait`} />
  </div>
</div>
